# -----------------------------------------------------------------------------
# Entorno General
# -----------------------------------------------------------------------------
NODE_ENV=development

# URL base del despliegue (ej. https://tu-app.vercel.app o http://localhost:3001)
# En Vercel, esto suele ser la URL del proyecto.
BASE_URL=http://localhost:3001
NEXT_PUBLIC_BASE_URL=http://localhost:3001

# Prefijo de ruta si la app no está en la raíz (ej. /app)
# Dejar vacío si se despliega en la raíz de un dominio/subdominio.
BASE_PATH=

# -----------------------------------------------------------------------------
# Base de Datos (Supabase)
# -----------------------------------------------------------------------------
# URL de conexión (Transaction mode recomendado para Vercel/Serverless)
DATABASE_URL=postgres://postgres:[PASSWORD]@[HOST]:[PORT]/[DB_NAME]

# Seeding (poner en "true" solo para la primera ejecución o pruebas)
# PRECAUCIÓN: En producción debe estar siempre en "false".
RUN_SEED=false

# -----------------------------------------------------------------------------
# Autenticación (Better-Auth)
# -----------------------------------------------------------------------------
# URL interna para el cliente de autenticación
BETTER_AUTH_URL=http://localhost:3001
# Secreto para firmar sesiones (Generar uno fuerte para producción)
BETTER_AUTH_SECRET=un_secreto_muy_largo_y_seguro

# -----------------------------------------------------------------------------
# Configuración Regional (i18n)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_LOCALE=es

# -----------------------------------------------------------------------------
# Seguridad (CORS)
# -----------------------------------------------------------------------------
# Origen permitido para peticiones externas (opcional)
CORS_ORIGIN=http://localhost:3001
