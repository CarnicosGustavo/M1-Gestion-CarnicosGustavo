# Base URL for the app (e.g. https://your-app.vercel.app)
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=your_secret_here

# Database connection string (e.g. Supabase)
# If empty, the app will use local PGLite (not recommended for Vercel)
DATABASE_URL=postgres://user:password@host:port/dbname

# Seeding (set to "true" to run seed on next startup)
RUN_SEED=false

# Locale
NEXT_PUBLIC_LOCALE=es
