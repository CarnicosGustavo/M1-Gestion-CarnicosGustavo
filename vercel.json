{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    }
  ],
  "redirects": [
    { "source": "/en", "destination": "/login", "permanent": true },
    { "source": "/en/", "destination": "/login", "permanent": true },
    { "source": "/en/:path*", "destination": "/:path*", "permanent": true }
  ]
}
